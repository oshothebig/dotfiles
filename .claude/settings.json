{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{ file_path=$(jq -r '.tool_input.file_path // .tool_response.filePath') && [[ \"$(basename \"$file_path\")\" == \"justfile\" ]] && just format; } 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
